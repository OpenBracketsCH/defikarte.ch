{
  "name": "defikarte-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app",
    "web",
    "shared"
  ],
  "scripts": {
    "app:start": "npm run start --workspace=app",
    "app:android": "npm run android --workspace=app",
    "app:ios": "npm run ios --workspace=app",
    "web:dev": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web --omit=optional",
    "install:web-prod": "npm ci --workspace=shared --workspace=web",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}